---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rentoasennus Autokorjaus",
  description = "Ammattimainen autokorjaus Akaassa. 60 €/h, selkeä hinta, rehellinen tekijä. Niko Poikkeus.",
} = Astro.props;
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --color-bg: #080808;
        --color-surface: #111111;
        --color-surface-raised: #0e0e0e;
        --color-accent: #3b82f6;
        --color-accent-light: #60a5fa;

        --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        --ease-out: cubic-bezier(0.16, 1, 0.3, 1);

        --shadow-diffuse:
          0 0 0 1px rgba(96, 165, 250, 0.08),
          0 20px 60px rgba(0, 0, 0, 0.55),
          0 0 80px rgba(59, 130, 246, 0.04);

        --shadow-diffuse-hover:
          0 0 0 1px rgba(96, 165, 250, 0.22),
          0 24px 80px rgba(0, 0, 0, 0.6),
          0 0 100px rgba(59, 130, 246, 0.09);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        background-color: var(--color-bg);
        color: #f5f5f5;
        font-family: 'Outfit', sans-serif;
        font-weight: 400;
        overflow-x: hidden;
      }

      h1, h2, h3, h4 {
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.03em;
        font-weight: 700;
      }

      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: #080808; }
      ::-webkit-scrollbar-thumb { background: var(--color-accent); }
      ::selection { background: var(--color-accent); color: #080808; }

      /* ── Scroll reveal ─────────────────────────────────────────────────────── */
      .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.5s var(--ease-out),
          transform 0.5s var(--ease-out);
        will-change: opacity, transform;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal-scale {
        opacity: 0;
        transform: scale(0.96) translateY(12px);
        transition:
          opacity 0.45s var(--ease-out),
          transform 0.45s var(--ease-out),
          box-shadow 0.45s var(--ease-out);
        will-change: opacity, transform, box-shadow;
      }

      .reveal-scale.is-visible {
        opacity: 1;
        transform: scale(1) translateY(0);
        box-shadow: var(--shadow-diffuse-hover);
      }

      .reveal-delay-1 { transition-delay: 0.07s; }
      .reveal-delay-2 { transition-delay: 0.14s; }
      .reveal-delay-3 { transition-delay: 0.21s; }
      .reveal-delay-4 { transition-delay: 0.28s; }
      .reveal-delay-5 { transition-delay: 0.35s; }

      /* ── Shared card styles ─────────────────────────────────────────────────── */
      .card {
        background: var(--color-surface-raised);
        border-radius: 2.5rem;
        padding: 2rem 2rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-diffuse);
        transition:
          box-shadow 0.45s var(--ease-out),
          transform 0.45s var(--spring),
          background-color 0.3s ease;
        will-change: transform, box-shadow;
      }

      .card:hover {
        box-shadow: var(--shadow-diffuse-hover);
        transform: translateY(-3px);
        background-color: #141414;
      }

      .card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(96,165,250,0.7), transparent);
        opacity: 0;
        transition: opacity 0.4s ease;
      }

      .card:hover::before { opacity: 1; }

      /* ── Page hero (subpages) ──────────────────────────────────────────────── */
      /* Nav is sticky on subpages — takes its own space, no offset needed */
      .page-hero {
        padding-top: 4rem;
        padding-bottom: 4rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 4rem;
      }

      @media (min-width: 768px) {
        .page-hero { padding-top: 5rem; padding-bottom: 5rem; margin-bottom: 5rem; }
      }

      @media (min-width: 1024px) {
        .page-hero { padding-top: 6rem; padding-bottom: 6rem; }
      }

      @media (max-width: 480px) {
        .card {
          padding: 1.25rem;
          border-radius: 1.5rem;
        }
        .page-hero {
          padding-top: 3rem;
          padding-bottom: 3rem;
          margin-bottom: 3rem;
        }
      }
    </style>

    <script>
      /* Shared scroll reveal for all pages */
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal, .reveal-scale').forEach((el) => {
          if (!el.closest('#hero')) observer.observe(el);
        });
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
