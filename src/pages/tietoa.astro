---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: "Rehellisyys",
    desc: "Kerrotaan suoraan, mikä on vialla ja mitä se maksaa — ennen kuin ruuvi kääntyy. Ei ylidiagnosointia, ei tarpeettomia osia.",
    icon: `<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: "Laatu",
    desc: "Jokainen työ tehdään alusta loppuun itse. Käytetään laadukkaita varaosia ja varmistetaan, että auto lähtee kunnossa.",
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    title: "Selkeä hinta",
    desc: "60 €/h — ei piilokuluja. Öljynvaihto 45 € (työ) + öljyt. Hinta kerrotaan ennen töiden aloittamista, ei jälkeen.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/>`,
  },
];
---

<Layout title="Tietoa meistä — Rentoasennus" description="Rentoasennus on Niko Poikkeuksen perustama autokorjaamo Akaassa. Ammattimainen korjaus, selkeä hinta, vuodesta 2025.">
  <Nav />

  <!-- Page hero -->
  <div class="page-hero max-w-7xl mx-auto px-6 lg:px-12 reveal">
    <p class="text-blue-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Meidän tarina</p>
    <div class="flex items-end gap-8">
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">Tietoa meistä</h1>
      <div class="hidden md:block flex-1 h-px bg-white/10 mb-2"></div>
    </div>
  </div>

  <!-- Story + image -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 pb-28 lg:pb-40">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-28">

      <!-- Image -->
      <div class="relative reveal">
        <div class="relative z-10 aspect-[4/5] overflow-hidden">
          <img
            src="/assets/generated/mechanic_portrait.png"
            alt="Niko Poikkeus, Rentoasennus"
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/60 via-transparent to-transparent pointer-events-none"></div>
        </div>
        <div class="absolute -bottom-8 right-2 sm:-right-4 lg:-right-12 w-32 sm:w-48 lg:w-56 aspect-square overflow-hidden border-4 border-[#080808] z-20 rounded-[2rem]">
          <img
            src="/assets/generated/engine.png"
            alt="Moottori"
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          />
        </div>
        <div class="absolute top-8 -left-4 lg:-left-6 w-px h-40 bg-gradient-to-b from-blue-400 to-transparent"></div>
      </div>

      <!-- Text -->
      <div class="lg:pl-8 reveal reveal-delay-1">
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-8">
          Yksi ammattilainen.<br/>
          <span class="text-zinc-500 font-light">Koko sydämellä.</span>
        </h2>
        <div class="space-y-5 text-zinc-300 text-lg font-light leading-relaxed">
          <p>
            Niko Poikkeus perusti Rentoasennus Tmi:n vuonna 2025 Akaaseen. Idea oli yksinkertainen: ammattimainen autokorjaus ilman turhia kuluja ja epäselviä hintoja.
          </p>
          <p>
            Yksin tehdessä jokainen auto on henkilökohtainen projekti. Ei alihankkijoita, ei välikäsiä — Niko tekee työn alusta loppuun itse ja kertoo suoraan, mitä tarvitaan ja mitä se maksaa.
          </p>
          <p>
            60 €/h tuntihinnalla saat ammattitaitoisen korjauksen ilman isoja firmoja ja niiden yleiskuluja. Reilu diili, rehellinen tekijä.
          </p>
        </div>

        <!-- Stats -->
        <div class="mt-10 pt-10 border-t border-white/8 grid grid-cols-3 gap-6">
          {[
            { number: "60 €", label: "Tuntihinta" },
            { number: "2025", label: "Perustettu" },
            { number: "100%", label: "Läpinäkyvyys" },
          ].map((stat, i) => (
            <div class={`reveal reveal-delay-${i + 1}`}>
              <div class="text-3xl font-bold text-blue-400 mb-1 tabular-nums">{stat.number}</div>
              <div class="text-zinc-600 text-xs tracking-wide uppercase">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Team — just Niko -->
    <div class="mb-28">
      <div class="mb-12 reveal">
        <p class="text-blue-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Tekijä</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white">Niko Poikkeus</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card reveal-scale flex flex-col items-start gap-5">
          <div class="w-14 h-14 rounded-2xl bg-blue-400/10 border border-blue-400/20 flex items-center justify-center">
            <span class="text-blue-400 font-bold text-lg tracking-widest">NP</span>
          </div>
          <div>
            <h3 class="text-white font-semibold text-xl mb-1">Niko Poikkeus</h3>
            <p class="text-blue-400/80 text-sm tracking-wide uppercase font-light mb-2">Yrittäjä & mekaanikkko</p>
            <p class="text-zinc-500 text-sm">Rentoasennus Tmi · Akaa</p>
          </div>
        </div>
        <div class="card reveal-scale reveal-delay-1 flex flex-col justify-between">
          <p class="text-zinc-400 text-base leading-relaxed font-light">
            "Haluan tehdä autokorjauksesta yksinkertaista. Selkeä hinta, rehellinen arvio, hyvä työ — se on kaikki mitä tarvitaan."
          </p>
          <a href="tel:0453141977" class="mt-6 text-blue-400 text-sm tracking-widest uppercase font-medium hover:text-blue-300 transition-colors duration-200">
            045 314 1977 →
          </a>
        </div>
      </div>
    </div>

    <!-- Values -->
    <div>
      <div class="mb-12 reveal">
        <p class="text-blue-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Arvomme</p>
        <h2 class="text-4xl md:text-5xl font-bold text-white">Miksi Rentoasennus?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {values.map((v, i) => (
          <div class={`card reveal-scale reveal-delay-${i + 1}`}>
            <div class="text-blue-400/60 mb-5">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" set:html={v.icon} />
            </div>
            <h3 class="text-white font-semibold text-2xl mb-3">{v.title}</h3>
            <p class="text-zinc-400 text-base leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
