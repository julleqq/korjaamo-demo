---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Varaa huoltoaika — Mäkinen Autokorjaamo" description="Varaa huoltoaika Mäkinen Autokorjaamolle helposti verkossa. Nopea ja vaivaton ajanvaraus.">
  <Nav />

  <!-- Page hero -->
  <div class="page-hero max-w-7xl mx-auto px-6 lg:px-12 reveal">
    <p class="text-blue-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Ajanvaraus</p>
    <div class="flex items-end gap-8">
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">Varaa huoltoaika</h1>
      <div class="hidden md:block flex-1 h-px bg-white/10 mb-2"></div>
    </div>
    <p class="text-zinc-400 text-lg font-light mt-6 max-w-xl leading-relaxed">
      Valitse sinulle sopiva aika alla olevasta kalenterista. Saat vahvistuksen sähköpostiin heti varauksen jälkeen.
    </p>
  </div>

  <!-- Booking placeholder -->
  <section class="max-w-5xl mx-auto px-6 lg:px-12 pb-28 lg:pb-40 reveal">
    <div class="card flex flex-col items-center text-center py-20 px-8 gap-6">
      <!-- Calendar icon -->
      <div class="w-16 h-16 rounded-full bg-blue-400/10 flex items-center justify-center shrink-0">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
      </div>
      <div>
        <h2 class="text-white font-bold text-2xl mb-3">Ajanvaraus tulossa pian</h2>
        <p class="text-zinc-400 font-light max-w-sm leading-relaxed">
          Verkkoajanvaraus avataan lähiaikoina. Tällä hetkellä voit varata ajan puhelimitse tai sähköpostilla — vastaamme nopeasti.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a href="tel:0453141977" class="group inline-flex items-center gap-3 bg-blue-400 text-zinc-950 font-semibold text-sm tracking-wider uppercase px-8 py-4 hover:bg-blue-300 transition-all duration-[400ms] whitespace-nowrap" style="transition-timing-function: var(--spring);">
          Soita nyt
          <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="group-hover:translate-x-1 transition-transform duration-300"><path d="M1 5H15M15 5L11 1M15 5L11 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="mailto:info@makinenkorjaamo.fi" class="inline-flex items-center gap-3 border border-white/20 text-white/80 hover:text-white hover:border-white/40 text-sm tracking-wider uppercase px-8 py-4 transition-all duration-300 font-light whitespace-nowrap">
          Lähetä sähköpostia
        </a>
      </div>
    </div>

    <!-- Alternative CTA -->
    <div class="mt-12 pt-10 border-t border-white/5 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between reveal">
      <div>
        <p class="text-white font-semibold text-xl mb-1">Puhelinpalvelu</p>
        <p class="text-zinc-400 font-light">Soita meille ma–pe 8–17.30, la 9–14.</p>
      </div>
      <a href="tel:0453141977" class="group inline-flex items-center gap-3 bg-blue-400 text-zinc-950 font-semibold text-sm tracking-wider uppercase px-8 py-4 hover:bg-blue-300 transition-all duration-[400ms] whitespace-nowrap" style="transition-timing-function: var(--spring);">
        Soita nyt
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="group-hover:translate-x-1 transition-transform duration-300"><path d="M1 5H15M15 5L11 1M15 5L11 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

