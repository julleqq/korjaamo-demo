---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Varaa huoltoaika — Mäkinen Autokorjaamo" description="Varaa huoltoaika Mäkinen Autokorjaamolle helposti verkossa. Nopea ja vaivaton ajanvaraus.">
  <Nav />

  <!-- Page hero -->
  <div class="page-hero max-w-7xl mx-auto px-6 lg:px-12 reveal">
    <p class="text-amber-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Ajanvaraus</p>
    <div class="flex items-end gap-8">
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">Varaa huoltoaika</h1>
      <div class="hidden md:block flex-1 h-px bg-white/10 mb-2"></div>
    </div>
    <p class="text-zinc-400 text-lg font-light mt-6 max-w-xl leading-relaxed">
      Valitse sinulle sopiva aika alla olevasta kalenterista. Saat vahvistuksen sähköpostiin heti varauksen jälkeen.
    </p>
  </div>

  <!-- Calendly embed -->
  <section class="max-w-5xl mx-auto px-6 lg:px-12 pb-28 lg:pb-40 reveal">
    <div class="calendly-wrap">
      <div
        class="calendly-inline-widget"
        data-url="https://calendly.com/YOUR_USERNAME?hide_landing_page_details=1&hide_gdpr_banner=1&background_color=0e0e0e&text_color=f5f5f5&primary_color=d97706"
        style="min-width:320px; height:700px;"
      ></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
    </div>

    <!-- Placeholder shown until Calendly account is connected -->
    <noscript>
      <div class="card text-center py-16">
        <p class="text-zinc-400">Ajanvarauskalenteri vaatii JavaScriptin. <a href="/yhteystiedot" class="text-amber-400 hover:underline">Ota yhteyttä puhelimitse.</a></p>
      </div>
    </noscript>

    <!-- Setup note (remove once Calendly is configured) -->
    <div id="calendly-setup-note" class="mt-6 flex items-start gap-3 text-zinc-600 text-sm p-4 border border-white/5 rounded-2xl">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="shrink-0 mt-0.5 text-amber-400/50"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
      <p>
        <strong class="text-zinc-400">Asennusohje:</strong> Luo ilmainen tili osoitteessa
        <span class="text-amber-400/70">calendly.com</span>, kopioi profiilisi URL-osoite ja korvaa
        <code class="text-amber-400/70 text-xs">YOUR_USERNAME</code> tiedostossa
        <code class="text-zinc-500 text-xs">src/pages/varaa-aika.astro</code>.
        Poista tämä ohjeteksti sen jälkeen.
      </p>
    </div>

    <!-- Alternative CTA -->
    <div class="mt-12 pt-10 border-t border-white/5 flex flex-col sm:flex-row items-start sm:items-center gap-6 justify-between reveal">
      <div>
        <p class="text-white font-semibold text-xl mb-1">Mieluummin puhelimitse?</p>
        <p class="text-zinc-400 font-light">Soita meille ma–pe 8–17.30, la 9–14.</p>
      </div>
      <a href="tel:0975764400" class="group inline-flex items-center gap-3 bg-amber-400 text-zinc-950 font-semibold text-sm tracking-wider uppercase px-8 py-4 hover:bg-amber-300 transition-all duration-[400ms] whitespace-nowrap" style="transition-timing-function: var(--spring);">
        Soita nyt
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="group-hover:translate-x-1 transition-transform duration-300"><path d="M1 5H15M15 5L11 1M15 5L11 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .calendly-wrap {
    background: var(--color-surface-raised);
    border-radius: 2.5rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: var(--shadow-diffuse);
  }
</style>
