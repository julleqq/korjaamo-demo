---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Yhteystiedot — Rentoasennus" description="Ota yhteyttä Rentoasennus Tmi:hin. Hämeentie 92, Akaa. Niko Poikkeus: 045 314 1977.">
  <Nav />

  <!-- Page hero -->
  <div class="page-hero max-w-7xl mx-auto px-6 lg:px-12 reveal">
    <p class="text-blue-400 text-xs tracking-[0.4em] uppercase font-light mb-4">Ota yhteyttä</p>
    <div class="flex items-end gap-8">
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-none">Yhteystiedot</h1>
      <div class="hidden md:block flex-1 h-px bg-white/10 mb-2"></div>
    </div>
  </div>

  <section class="max-w-7xl mx-auto px-6 lg:px-12 pb-28 lg:pb-40">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">

      <!-- Left: info cards -->
      <div class="flex flex-col gap-4">

        <div class="card reveal-scale">
          <div class="text-blue-400 mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <p class="text-zinc-500 text-sm tracking-widest uppercase mb-4">Osoite</p>
          <p class="text-white text-xl font-semibold leading-tight">Hämeentie 92</p>
          <p class="text-white text-xl font-semibold leading-tight">37800 Akaa</p>
          <p class="text-zinc-600 text-xs mt-3">Pirkanmaa</p>
        </div>

        <div class="card reveal-scale reveal-delay-1">
          <div class="text-blue-400 mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <p class="text-zinc-500 text-sm tracking-widest uppercase mb-4">Aukioloajat</p>
          <p class="text-white text-xl font-semibold leading-tight">Ma–Pe: 8.00–17.00</p>
          <p class="text-white text-xl font-semibold leading-tight">La sopimuksen mukaan</p>
          <p class="text-zinc-600 text-xs mt-3">Soita tai lähetä viesti</p>
        </div>

        <div class="card reveal-scale reveal-delay-2">
          <div class="text-blue-400 mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.01 1.17 2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14v2.92z"/></svg>
          </div>
          <p class="text-zinc-500 text-sm tracking-widest uppercase mb-4">Puhelin & sähköposti</p>
          <a href="tel:0453141977" class="block text-white text-xl font-semibold leading-tight hover:text-blue-400 transition-colors duration-200">045 314 1977</a>
          <p class="text-white text-xl font-semibold leading-tight">Niko Poikkeus</p>
          <p class="text-zinc-600 text-xs mt-3">Soita tai lähetä viesti</p>
        </div>

      </div>

      <!-- Right: contact form -->
      <div class="reveal reveal-delay-1">
        <div class="card" style="border-radius: 2.5rem; padding: 2.5rem;">
          <h2 class="text-white font-bold text-2xl mb-2">Lähetä viesti</h2>
          <p class="text-zinc-500 text-sm mb-8">Vastaamme saman päivän aikana ma–pe.</p>

          <form action="#" class="flex flex-col gap-5" onsubmit="return false;">

            <div class="flex flex-col gap-2">
              <label class="text-zinc-400 text-xs tracking-widest uppercase" for="nimi">Nimi</label>
              <input
                id="nimi" name="nimi" type="text" placeholder="Matti Virtanen"
                class="contact-input"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label class="text-zinc-400 text-xs tracking-widest uppercase" for="email">Sähköposti</label>
              <input
                id="email" name="email" type="email" placeholder="matti@esimerkki.fi"
                class="contact-input"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label class="text-zinc-400 text-xs tracking-widest uppercase" for="puhelin">Puhelinnumero</label>
              <input
                id="puhelin" name="puhelin" type="tel" placeholder="040 123 4567"
                class="contact-input"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label class="text-zinc-400 text-xs tracking-widest uppercase" for="viesti">Viesti</label>
              <textarea
                id="viesti" name="viesti" rows="5"
                placeholder="Kerro autosi merkki, malli ja vuosimalli sekä mitä huoltoa tarvitset..."
                class="contact-input resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-400 text-zinc-950 font-semibold text-sm tracking-widest uppercase px-8 py-4 hover:bg-blue-300 transition-all duration-[400ms] mt-2"
              style="transition-timing-function: var(--spring);"
            >
              Lähetä viesti
            </button>

          </form>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-input {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    color: white;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    width: 100%;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .contact-input::placeholder { color: rgba(255,255,255,0.2); }
  .contact-input:focus { border-color: rgba(96,165,250,0.5); }
</style>
